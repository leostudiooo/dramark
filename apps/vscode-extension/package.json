{
  "name": "dramark",
  "displayName": "DraMark",
  "description": "DraMark — Drama Markdown language support",
  
  "license": "MIT",
  "publisher": "dramark",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "extensionPack": ["redhat.vscode-yaml"],
  "contributes": {
    "languages": [
      {
        "id": "dramark",
        "aliases": ["DraMark", "dramark"],
        "extensions": [".dramark", ".drm", ".drm.md"],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "dramark.showPreview",
        "title": "DraMark: Show Preview",
        "icon": "$(preview)"
      },
      {
        "command": "dramark.copyDiagnostics",
        "title": "DraMark: Copy Diagnostics"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "dramark.showPreview",
          "when": "resourceLangId == dramark",
          "group": "navigation@10"
        }
      ]
    },
    "grammars": [
      {
        "language": "dramark",
        "scopeName": "source.dramark",
        "path": "./dramark.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.frontmatter.dramark": "yaml"
        }
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0"
  }
}
