{
  "name": "dramark",
  "displayName": "DraMark",
  "description": "DraMark — Drama Markdown language support",
  "repository": {
    "type": "git",
    "url": "https://github.com/dramark-md/dramark.git"
  },
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "LeoLi",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "extensionPack": [
    "redhat.vscode-yaml"
  ],
  "contributes": {
    "languages": [
      {
        "id": "dramark",
        "aliases": [
          "DraMark",
          "dramark"
        ],
        "extensions": [
          ".dramark",
          ".drm",
          ".dra.md",
          ".dra.markdown"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "dramark.showPreview",
        "title": "DraMark: Show Preview",
        "icon": "$(preview)"
      },
      {
        "command": "dramark.export",
        "title": "DraMark: Export...",
        "icon": "$(export)"
      },
      {
        "command": "dramark.copyDiagnostics",
        "title": "DraMark: Copy Diagnostics"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "dramark.showPreview",
          "when": "resourceLangId == dramark",
          "group": "navigation@10"
        }
      ],
      "editor/context": [
        {
          "command": "dramark.showPreview",
          "when": "resourceLangId == dramark",
          "group": "dramark@1"
        },
        {
          "command": "dramark.export",
          "when": "resourceLangId == dramark",
          "group": "dramark@2"
        }
      ],
      "explorer/context": [
        {
          "command": "dramark.showPreview",
          "when": "resourceLangId == dramark",
          "group": "dramark@1"
        },
        {
          "command": "dramark.export",
          "when": "resourceLangId == dramark || resourceExtname == .dra.md || resourceExtname == .dramark || resourceExtname == .drm",
          "group": "dramark@2"
        }
      ]
    },
    "grammars": [
      {
        "language": "dramark",
        "scopeName": "source.dramark",
        "path": "./dramark.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.frontmatter.dramark": "yaml"
        }
      }
    ],
    "configuration": {
      "title": "DraMark",
      "properties": {
        "dramark.pdf.chromePath": {
          "type": "string",
          "default": "",
          "description": "Path to Chrome/Chromium executable. Leave empty for auto-detection."
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "package:vsix": "npm run build && vsce package",
    "package:vsix:out": "npm run build && vsce package -o dist/dramark.vsix"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0"
  },
  "dependencies": {
    "@vscode/vsce": "^3.7.1",
    "puppeteer-core": "^23.11.1"
  }
}
