{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DraMark",
  "scopeName": "source.dramark",
  "patterns": [
    { "include": "#frontmatter" },
    { "include": "#comment-block" },
    { "include": "#comment-line" },
    { "include": "#comment-inline" },
    { "include": "#character-name" },
    { "include": "#scene-break" },
    { "include": "#song-container" },
    { "include": "#block-tech-cue" },
    { "include": "#translation-source" },
    { "include": "#inline-song" },
    { "include": "#inline-tech-cue" },
    { "include": "#inline-action" }
  ],
  "repository": {
    "frontmatter": {
      "begin": "\\A---",
      "end": "^---\\s*$",
      "contentName": "meta.embedded.block.frontmatter.dramark",
      "patterns": [
        { "include": "source.yaml" }
      ]
    },
    "comment-line": {
      "match": "^\\s*%(?!%).*$",
      "name": "comment.line.percent.dramark"
    },
    "comment-block": {
      "begin": "^\\s*%%\\s*$",
      "end": "^\\s*%%\\s*$",
      "name": "comment.block.percent.dramark"
    },
    "comment-inline": {
      "match": "(?<=\\s)%(?!%).*$",
      "name": "comment.line.percent.dramark"
    },
    "character-name": {
      "match": "^@(?!@)([\\S]+(?:\\s+[\\S]+)*)",
      "captures": {
        "1": { "name": "entity.name.character.dramark" }
      }
    },
    "scene-break": {
      "match": "^(?:---|\\*\\*\\*)\\s*$",
      "name": "keyword.control.scene-break.dramark"
    },
    "song-container": {
      "begin": "^(\\$\\$)(?:\\s+(.*))?\\s*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.song-boundary.dramark" },
        "2": { "name": "entity.name.section.song-title.dramark" }
      },
      "end": "^(\\$\\$)\\s*$",
      "endCaptures": {
        "1": { "name": "keyword.control.song-boundary.dramark" }
      },
      "patterns": [
        { "include": "#comment-block" },
        { "include": "#comment-line" },
        { "include": "#comment-inline" },
        { "include": "#character-name" },
        { "include": "#block-tech-cue" },
        { "include": "#translation-source" },
        { "include": "#inline-song" },
        { "include": "#inline-tech-cue" },
        { "include": "#inline-action" }
      ]
    },
    "block-tech-cue": {
      "begin": "^(\\s*<<<)(?!<)(?:\\s+(.*))?\\s*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.tech-cue-boundary.dramark" },
        "2": { "name": "support.function.tech-cue.dramark" }
      },
      "end": "^(\\s*(?:>>>|<<<))\\s*$",
      "endCaptures": {
        "1": { "name": "keyword.control.tech-cue-boundary.dramark" }
      },
      "patterns": [
        { "include": "#comment-block" },
        { "include": "#comment-line" },
        { "include": "#comment-inline" },
        { "include": "#inline-song" },
        { "include": "#inline-action" }
      ]
    },
    "translation-source": {
      "match": "^=\\s+(.*)$",
      "name": "string.other.translation-source.dramark"
    },
    "inline-song": {
      "match": "(?<!\\\\)\\$(?!\\$)([^$]+)(?<!\\\\)\\$(?!\\$)",
      "name": "string.quoted.other.song.dramark"
    },
    "inline-tech-cue": {
      "match": "(?<!\\\\)(?<!<)<<(?!<)([^>]+)(?<!>)>>(?!>)",
      "name": "support.function.tech-cue.dramark"
    },
    "inline-action": {
      "match": "(?<!\\\\)[{｛]([^}｝]+)[}｝]",
      "name": "markup.other.action.dramark"
    }
  }
}
