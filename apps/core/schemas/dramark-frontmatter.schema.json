{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dramark-frontmatter",
  "title": "DraMark Frontmatter",
  "description": "Configuration schema for DraMark script frontmatter",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "description": "Document metadata",
      "additionalProperties": true
    },
    "casting": {
      "type": "object",
      "description": "Cast configuration",
      "properties": {
        "characters": {
          "type": "array",
          "description": "Character definitions",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Character display name"
              },
              "id": {
                "type": "string",
                "description": "Unique character identifier"
              },
              "actor": {
                "type": "string",
                "description": "Assigned actor name"
              },
              "mic": {
                "type": "string",
                "description": "Assigned microphone ID"
              },
              "aliases": {
                "type": "array",
                "description": "Alternative names for this character",
                "items": { "type": "string" }
              }
            }
          }
        },
        "groups": {
          "type": "object",
          "description": "Character groups",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "members": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "translation": {
      "type": "object",
      "description": "Translation settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable translation pair parsing",
          "default": false
        },
        "source_lang": {
          "type": "string",
          "description": "Source language code (e.g. en)"
        },
        "target_lang": {
          "type": "string",
          "description": "Target language code (e.g. zh)"
        },
        "render": {
          "type": "string",
          "description": "Render mode for translation pairs"
        }
      }
    },
    "tech": {
      "type": "object",
      "description": "Technical cue configuration",
      "additionalProperties": {
        "oneOf": [
          {
            "$ref": "#/definitions/techCategory"
          },
          {
            "type": "array",
            "description": "Array of tech entries (legacy format for mics or as fallback)",
            "items": {
              "$ref": "#/definitions/techEntry"
            }
          }
        ]
      },
      "properties": {
        "mics": {
          "type": "array",
          "description": "Reserved field for microphone definitions (array structure only)",
          "items": {
            "$ref": "#/definitions/techEntry"
          }
        },
        "color": {
          "type": "string",
          "description": "Fallback color for unmatched tech cues (hex format)"
        }
      }
    }
  },
  "definitions": {
    "techEntry": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Tech cue identifier"
        },
        "label": {
          "type": "string",
          "description": "Display label"
        },
        "desc": {
          "type": "string",
          "description": "Description of the tech cue"
        }
      }
    },
    "techCategory": {
      "type": "object",
      "description": "Dynamic tech category with color and entries",
      "properties": {
        "color": {
          "type": "string",
          "description": "Color for tech cues in this category (hex format)"
        },
        "entries": {
          "type": "array",
          "description": "Entries in this category",
          "items": {
            "$ref": "#/definitions/techEntry"
          }
        }
      }
    }
  }
}
