{
  "name": "remark-dramark",
  "version": "0.1.0",
  "description": "Remark plugin for DraMark - Drama Markdown language",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/leostudiooo/dramark.git"
  },
  "bugs": {
    "url": "https://github.com/leostudiooo/dramark/issues"
  },
  "homepage": "https://github.com/leostudiooo/dramark#readme",
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "license": "Apache-2.0",
  "keywords": [
    "remark",
    "dramark",
    "markdown",
    "drama",
    "theater",
    "musical"
  ],
  "dependencies": {
    "mdast": "^3.0.0",
    "mdast-util-from-markdown": "^2.0.0",
    "micromark-util-types": "^2.0.0",
    "unified": "^11.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "typescript": "^5.3.0",
    "vfile": "^6.0.3",
    "vitest": "^1.0.0"
  }
}
